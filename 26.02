from flask import Flask, request, session, redirect
import json
import os

app = Flask(__name__)
app.secret_key = 'supersecretkey123'  # для работы session

# файл для хранения пользователей
USERS_FILE = 'users.json'

# функция загрузки пользователей из JSON
def load_users():
    if os.path.exists(USERS_FILE):
        with open(USERS_FILE, 'r', encoding='utf-8') as f:
            return json.load(f)
    return {}
# функция сохранения пользователей в JSON
def save_users(users):
    with open(USERS_FILE, 'w', encoding='utf-8') as f:
        json.dump(users, f, ensure_ascii=False, indent=4)

@app.route('/')
def home():
    if 'username' in session:
        username = session['username']
        return f'''
            <h1>Главная страница</h1>
            <p>Привет, {username}!</p>
            <a href="/profile">Личный кабинет</a><br>
            <a href="/logout">Выйти</a>
        '''
    else:
        return '''
            <h1>Главная страница</h1>
            <a href="/register">Регистрация</a><br>
            <a href="/login">Вход</a>
        '''

@app.route('/register', methods=['GET', 'POST'])
def register():
    if request.method == 'POST':
        username = request.form['username']
        email = request.form['email']
        password = request.form['password']
        
        users = load_users()
        
        if username in users:
            return 'Пользователь уже существует! <a href="/register">Попробовать снова</a>'
        
        users[username] = {
            'email': email,
            'password': password,
            'bio': ''
        }
        save_users(users)
        
        return 'Регистрация успешна! <a href="/login">Войти</a>'
    else:
        return '''
            <h2>Регистрация</h2>
            <form method="post">
                <label>Имя пользователя:</label><br>
                <input type="text" name="username" required><br><br>
                
                <label>Email:</label><br>
                <input type="email" name="email" required><br><br>
                
                <label>Пароль:</label><br>
                <input type="password" name="password" required><br><br>
                
                <button type="submit">Зарегистрироваться</button>
            </form>
            <br><a href="/">На главную</a>
        '''

@app.route('/login', methods=['GET', 'POST'])
def login():
    if request.method == 'POST':
        username = request.form['username']
        password = request.form['password']
        
        users = load_users()
        
        if username in users and users[username]['password'] == password:
            session['username'] = username
            return redirect('/')
        else:
            return 'Неверное имя пользователя или пароль! <a href="/login">Попробовать снова</a>'
    else:
        return '''
            <h2>Вход</h2>
            <form method="post">
                <label>Имя пользователя:</label><br>
                <input type="text" name="username" required><br><br>
                
                <label>Пароль:</label><br>
                <input type="password" name="password" required><br><br>
                
                <button type="submit">Войти</button>
            </form>
            <br><a href="/">На главную</a>
        '''

@app.route('/logout')
def logout():
    if 'username' in session:
        session.pop('username')
    return redirect('/')

@app.route('/profile')
def profile():
    if 'username' not in session:
        return 'Сначала войдите! <a href="/login">Войти</a>'
    
    username = session['username']
    users = load_users()
    user = users[username]
    
    return f'''
        <h2>Личный кабинет</h2>
        <p><strong>Имя:</strong> {username}</p>
        <p><strong>Email:</strong> {user['email']}</p>
        <p><strong>О себе:</strong> {user['bio'] if user['bio'] else 'Не указано'}</p>
        <br>
        <a href="/edit">Редактировать профиль</a><br>
        <a href="/password">Сменить пароль</a><br>
        <a href="/logout">Выйти</a><br>
        <a href="/">На главную</a>
    '''

@app.route('/edit', methods=['GET', 'POST'])
def edit_profile():
    if 'username' not in session:
        return 'Сначала войдите! <a href="/login">Войти</a>'
    
    username = session['username']
    users = load_users()
    
    if request.method == 'POST':
        email = request.form['email']
        bio = request.form['bio']
        
        users[username]['email'] = email
        users[username]['bio'] = bio
        save_users(users)
        
        return 'Профиль обновлён! <a href="/profile">Назад в профиль</a>'
    else:
        user = users[username]
        return f'''
            <h2>Редактирование профиля</h2>
            <form method="post">
                <label>Email:</label><br>
                <input type="email" name="email" value="{user['email']}" required><br><br>
                
                <label>О себе:</label><br>
                <textarea name="bio">{user['bio']}</textarea><br><br>
                
                <button type="submit">Сохранить</button>
            </form>
            <br><a href="/profile">Отмена</a>
        '''

@app.route('/password', methods=['GET', 'POST'])
def change_password():
    if 'username' not in session:
        return 'Сначала войдите! <a href="/login">Войти</a>'
    
    username = session['username']
    users = load_users()
    
    if request.method == 'POST':
        old_password = request.form['old_password']
        new_password = request.form['new_password']
        confirm_password = request.form['confirm_password']
        
        if users[username]['password'] != old_password:
            return 'Неверный текущий пароль! <a href="/password">Попробовать снова</a>'
        
        if new_password != confirm_password:
            return 'Новые пароли не совпадают! <a href="/password">Попробовать снова</a>'
        
        users[username]['password'] = new_password
        save_users(users)
        
        return 'Пароль изменён! <a href="/profile">Назад в профиль</a>'
    else:
        return '''
            <h2>Смена пароля</h2>
            <form method="post">
                <label>Текущий пароль:</label><br>
                <input type="password" name="old_password" required><br><br>
                
                <label>Новый пароль:</label><br>
                <input type="password" name="new_password" required><br><br>
                
                <label>Подтвердите пароль:</label><br>
                <input type="password" name="confirm_password" required><br><br>
                
                <button type="submit">Изменить</button>
            </form>
            <br><a href="/profile">Отмена</a>
        '''

if __name__ == '__main__':
    app.run(debug=True)
